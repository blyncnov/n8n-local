# Copy this file to ".env" and fill in your own values:
#   cp .env.example .env
#
# The .env file holds your secrets and is NOT committed to git.

# --- Postgres database ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n

# --- n8n login (basic auth gate) ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me

# --- n8n encryption key ---
# Generate ONE key and keep it forever (never change it after first run):
#   openssl rand -hex 24
# It encrypts all saved credentials. Lose it = credentials unrecoverable.
N8N_ENCRYPTION_KEY=replace_with_random_string

# --- Timezone ---
# Use your IANA timezone so scheduled workflows run at the right local time.
# Find yours with:  readlink /etc/localtime | sed 's#.*/zoneinfo/##'
TIMEZONE=Africa/Lagos

# --- Public URL ---
# LOCAL ONLY (default): leave these as localhost / http.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
#
# WITH A CLOUDFLARE TUNNEL: point these at your domain instead, e.g.
#   N8N_HOST=n8n.example.com
#   N8N_PROTOCOL=https
#   N8N_WEBHOOK_URL=https://n8n.example.com/

# --- Cloudflare Tunnel (optional) ---
# To expose n8n on your domain via Cloudflare Tunnel, uncomment both lines,
# set your token, and make sure the tunnel's service points to http://localhost:5678
# in the Cloudflare dashboard. Leave commented for local-only use.
#COMPOSE_PROFILES=tunnel
#CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token
